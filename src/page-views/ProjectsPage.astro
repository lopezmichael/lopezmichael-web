---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCardWide from '../components/ProjectCardWide.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { projects } from '../data/projects';

const civicProjects = projects.filter((p) => p.category === 'civic');
const openSourceProjects = projects.filter((p) => p.category === 'open-source');
const personalProjects = projects.filter((p) => p.category === 'personal');
---

<BaseLayout
  title="Projects"
  description="Selected projects by Michael Lopez. Data pipelines, dashboards, open source tools, and community-driven data products."
>
  <div class="border-t-4 border-canyon">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <ScrollReveal>
        <h1 class="text-3xl lg:text-4xl font-bold tracking-tight mb-4">Projects</h1>
        <p class="text-base leading-relaxed opacity-80 max-w-2xl">
          A selection of data systems, tools, and products I've built, from production pipelines
          serving community partners to open-source packages and personal projects.
        </p>
      </ScrollReveal>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">

    <!-- Civic Data & Infrastructure -->
    <ScrollReveal>
      <h2 class="text-lg font-semibold text-primary dark:text-dark-text mb-6 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-canyon" aria-hidden="true"></span>
        Civic Data & Infrastructure
      </h2>
    </ScrollReveal>
    <div class="space-y-6 mb-16">
      {civicProjects.map((project, i) => (
        <ScrollReveal delay={i * 80}>
          <ProjectCardWide project={project} />
        </ScrollReveal>
      ))}
    </div>

    <!-- Personal Projects -->
    {personalProjects.length > 0 && (
      <>
        <ScrollReveal>
          <h2 class="text-lg font-semibold text-primary dark:text-dark-text mb-6 flex items-center gap-3">
            <span class="w-8 h-0.5 bg-canyon" aria-hidden="true"></span>
            Personal & Community
          </h2>
        </ScrollReveal>
        <div class="space-y-6 mb-16">
          {personalProjects.map((project, i) => (
            <ScrollReveal delay={i * 80}>
              <ProjectCardWide project={project} />
            </ScrollReveal>
          ))}
        </div>
      </>
    )}

    <!-- Open Source -->
    <ScrollReveal>
      <h2 class="text-lg font-semibold text-primary dark:text-dark-text mb-6 flex items-center gap-3">
        <span class="w-8 h-0.5 bg-canyon" aria-hidden="true"></span>
        Open Source
      </h2>
    </ScrollReveal>
    <div class="space-y-6">
      {openSourceProjects.map((project, i) => (
        <ScrollReveal delay={i * 80}>
          <ProjectCardWide project={project} />
        </ScrollReveal>
      ))}
    </div>
  </div>
</BaseLayout>
