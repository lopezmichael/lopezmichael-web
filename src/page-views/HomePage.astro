---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerrainHero from '../components/TerrainHero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { featuredProjects } from '../data/projects';
---

<BaseLayout
  title="Michael Lopez"
  description="Data Strategist at the intersection of civic tech and social impact. Building data systems that help communities."
>
  <TerrainHero />

  <!-- Intro Section -->
  <ScrollReveal>
    <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h2 class="text-2xl font-semibold text-primary dark:text-dark-text mb-4">
        Data should reach the people closest to the problem.
      </h2>
      <p class="text-lg leading-relaxed opacity-80">
        I lead data operations at the Child Poverty Action Lab, a backbone nonprofit working on
        child poverty across North Texas. My work runs from the platform underneath (pipelines,
        infrastructure, the team that builds them) up to the tools that get data in front of people
        who can act on it. The stubborn idea pulling it together: most of the data that could help
        families is sitting somewhere it can't reach them. Most of the job is closing that gap.
      </p>
    </section>
  </ScrollReveal>

  <!-- Featured Projects -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-20">
    <ScrollReveal>
      <h2 class="text-2xl font-semibold text-primary dark:text-dark-text text-center mb-10">
        Featured Work
      </h2>
    </ScrollReveal>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredProjects.map((project, i) => (
        <ScrollReveal delay={i * 100}>
          <ProjectCard project={project} />
        </ScrollReveal>
      ))}
    </div>
    <ScrollReveal>
      <div class="text-center mt-10">
        <a
          href="/projects/"
          class="inline-flex items-center gap-2 text-sm font-medium text-cool dark:text-secondary hover:text-secondary transition-colors no-underline"
        >
          View all projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>
