---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <p class="text-xl mb-8 opacity-75">The page you're looking for doesn't exist.</p>
    <a href="/" class="px-5 py-2.5 bg-primary text-white rounded-lg font-medium text-sm hover:bg-secondary transition-colors no-underline">
      Back to Home
    </a>
  </div>
</BaseLayout>
