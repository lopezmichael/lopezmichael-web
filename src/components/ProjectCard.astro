---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const detailHref = `/projects/${project.slug}/`;

// Map gradient keys to explicit classes so Tailwind can scan them
const gradientMap: Record<string, string> = {
  'from-canyon to-secondary': 'from-canyon to-secondary',
  'from-cool to-canyon': 'from-cool to-canyon',
  'from-secondary to-accent': 'from-secondary to-accent',
  'from-cool to-secondary': 'from-cool to-secondary',
  'from-canyon to-cool': 'from-canyon to-cool',
  'from-primary to-cool': 'from-primary to-cool',
  'from-cool to-primary': 'from-cool to-primary',
};
const gradientClasses = gradientMap[project.gradient] ?? 'from-canyon to-secondary';
---

<a
  href={detailHref}
  class="group block no-underline rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-2 bg-surface dark:bg-dark-surface"
>
  <!-- Screenshot or gradient header -->
  {project.image ? (
    <div class="h-40 overflow-hidden">
      <img
        src={project.image}
        alt={`Screenshot of ${project.title}`}
        width="1280"
        height="720"
        class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  ) : (
    <div class={`h-40 bg-gradient-to-br ${gradientClasses} opacity-80 group-hover:opacity-100 transition-opacity`}></div>
  )}

  <!-- Content -->
  <div class="p-5">
    <h3 class="text-lg font-semibold mb-2 dark:text-dark-text">{project.title}</h3>
    <p class="text-sm opacity-75 leading-relaxed mb-3 dark:text-dark-text">
      {project.description}
    </p>
    <div class="flex flex-wrap gap-2">
      {project.tags.map((tag) => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-accent/20 text-primary dark:bg-accent/15 dark:text-accent font-medium">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
