---
interface Props {
  title: string;
  company: string;
  dates: string;
  summary?: string;
  bullets: string[];
}

const { title, company, dates, summary, bullets } = Astro.props;
---

<div class="mb-8">
  <h4 class="text-base font-semibold text-neutral dark:text-dark-text">{title}</h4>
  <p class="text-primary dark:text-secondary font-medium text-sm mt-0.5">{company} &middot; {dates}</p>
  {summary && (
    <p class="text-sm italic mt-2 opacity-80">{summary}</p>
  )}
  <ul class="mt-2 space-y-1.5 list-disc list-outside ml-5">
    {bullets.map((bullet) => (
      <li class="text-sm leading-relaxed">{bullet}</li>
    ))}
  </ul>
</div>
