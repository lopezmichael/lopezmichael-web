---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const detailHref = `/projects/${project.slug}/`;
const isExternal = project.href.startsWith('http');

const gradientMap: Record<string, string> = {
  'from-canyon to-secondary': 'from-canyon to-secondary',
  'from-cool to-canyon': 'from-cool to-canyon',
  'from-secondary to-accent': 'from-secondary to-accent',
  'from-cool to-secondary': 'from-cool to-secondary',
  'from-canyon to-cool': 'from-canyon to-cool',
  'from-primary to-cool': 'from-primary to-cool',
  'from-cool to-primary': 'from-cool to-primary',
};
const gradientClasses = gradientMap[project.gradient] ?? 'from-canyon to-secondary';
---

<article class="relative rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 bg-surface dark:bg-dark-surface ring-1 ring-accent/30 dark:ring-dark-bg/40">
  <div class="md:flex">
    <!-- Screenshot or gradient side -->
    {(project.cardImage ?? project.image) ? (
      <div class="md:w-96 md:shrink-0 h-44 md:h-auto overflow-hidden">
        <img
          src={project.cardImage ?? project.image}
          alt={`Screenshot of ${project.title}`}
          width="1280"
          height="720"
          class="w-full h-full object-cover object-top"
          loading="lazy"
        />
      </div>
    ) : (
      <div class={`md:w-72 md:shrink-0 h-32 md:h-auto bg-gradient-to-br ${gradientClasses}`}></div>
    )}

    <!-- Content -->
    <div class="p-6 flex-1">
      <div class="flex items-start justify-between gap-4 mb-2">
        <h3 class="text-lg font-semibold dark:text-dark-text">
          <a
            href={detailHref}
            class="text-current no-underline hover:text-cool dark:hover:text-secondary transition-colors before:content-[''] before:absolute before:inset-0"
          >
            {project.title}
          </a>
        </h3>
        {isExternal && (
          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-10 shrink-0 inline-flex items-center gap-1 text-xs font-medium text-cool dark:text-secondary hover:text-secondary no-underline mt-1"
          >
            Visit
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
            </svg>
          </a>
        )}
      </div>

      <p class="text-sm leading-relaxed opacity-75 dark:text-dark-text mb-3">
        {project.longDescription}
      </p>

      {project.highlights && (
        <ul class="text-xs space-y-1 mb-3 opacity-80 dark:text-dark-text">
          {project.highlights.map((h) => (
            <li class="flex items-center gap-1.5">
              <span class="text-cool dark:text-accent font-bold" aria-hidden="true">&gt;</span>
              {h}
            </li>
          ))}
        </ul>
      )}

      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="text-xs px-2.5 py-1 rounded-full bg-accent/20 text-primary dark:bg-accent/15 dark:text-accent font-medium">
              {tag}
            </span>
          ))}
        </div>
        <span class="text-xs font-medium text-cool dark:text-secondary whitespace-nowrap">
          Project details →
        </span>
      </div>
    </div>
  </div>
</article>
