---
import { skills } from '../data/resume';
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
  {skills.map((cat) => (
    <div>
      <h3 class="text-sm font-semibold text-cool dark:text-secondary mb-3 pb-2 border-b-2 border-accent">
        {cat.label}
      </h3>
      <ul class="space-y-1.5">
        {cat.items.map((item) => (
          <li class="text-sm flex items-center gap-2">
            <span class="text-cool dark:text-accent font-bold text-xs">&gt;</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
