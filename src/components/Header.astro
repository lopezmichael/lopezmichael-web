---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Resume', href: '/resume/' },
];

function isActive(href: string, path: string): boolean {
  if (href === '/') return path === '/' || path === '';
  // Match with or without trailing slash
  const normalized = path.endsWith('/') ? path : path + '/';
  return normalized === href;
}
---

<header class="sticky top-0 z-40 bg-light/95 dark:bg-dark-bg/95 backdrop-blur-sm shadow-sm transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="text-primary dark:text-dark-text font-heading text-lg font-semibold">Michael Lopez</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors',
              isActive(item.href, currentPath)
                ? 'text-cool dark:text-secondary font-semibold'
                : 'text-neutral dark:text-dark-text hover:text-cool',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Social links -->
        <a href="https://github.com/lopezmichael" target="_blank" rel="noopener noreferrer" class="hidden lg:flex items-center justify-center w-9 h-9 text-neutral dark:text-dark-text hover:text-cool transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/michael-d-lopez" target="_blank" rel="noopener noreferrer" class="hidden lg:flex items-center justify-center w-9 h-9 text-neutral dark:text-dark-text hover:text-cool transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>

        <!-- CTA pill -->
        <a
          href="/work-with-me/"
          class="hidden md:inline-flex items-center px-3.5 py-1.5 rounded-full bg-secondary text-white text-xs font-semibold hover:bg-canyon transition-colors no-underline whitespace-nowrap"
        >
          Work with me
        </a>

        <ThemeToggle />

        <!-- Mobile hamburger -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center w-10 h-10 text-neutral dark:text-dark-text"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6" style="display:none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Drawer -->
<div id="mobile-menu" style="display:none" class="md:hidden fixed inset-x-0 top-16 bottom-0 bg-light dark:bg-dark-bg z-50 overflow-y-auto">
  <nav class="flex flex-col p-6 gap-1" aria-label="Mobile navigation">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'block py-3 text-lg font-medium border-b border-accent/30',
          isActive(item.href, currentPath)
            ? 'text-cool dark:text-secondary font-semibold'
            : 'text-neutral dark:text-dark-text hover:text-cool',
        ]}
      >
        {item.label}
      </a>
    ))}
    <a
      href="/work-with-me/"
      class="mt-6 block py-3 text-center text-base font-semibold rounded-lg bg-secondary text-white hover:bg-canyon transition-colors no-underline"
    >
      Work with me
    </a>
    <div class="flex gap-4 mt-6 pt-4">
      <a href="https://github.com/lopezmichael" target="_blank" rel="noopener noreferrer" class="text-neutral dark:text-dark-text hover:text-cool transition-colors" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/michael-d-lopez" target="_blank" rel="noopener noreferrer" class="text-neutral dark:text-dark-text hover:text-cool transition-colors" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>
  </nav>
</div>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-icon-open');
    const closeIcon = document.getElementById('menu-icon-close');

    if (!btn || !menu) return;

    // aria-expanded is the single source of truth for open state.
    const isOpen = () => btn.getAttribute('aria-expanded') === 'true';

    const setOpen = (open: boolean) => {
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.style.display = open ? 'block' : 'none';
      if (openIcon) openIcon.style.display = open ? 'none' : 'block';
      if (closeIcon) closeIcon.style.display = open ? 'block' : 'none';
      document.body.style.overflow = open ? 'hidden' : '';
    };

    btn.addEventListener('click', () => setOpen(!isOpen()));

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        setOpen(false);
        btn.focus();
      }
    });

    // Close on resize past mobile breakpoint to avoid stuck-open state.
    const mql = window.matchMedia('(min-width: 768px)');
    mql.addEventListener('change', (e) => {
      if (e.matches && isOpen()) setOpen(false);
    });
  }

  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
